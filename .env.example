# Neon PostgreSQL — use POOLED connection string (hostname contains -pooler)
DATABASE_URI=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Payload secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-32-char-minimum-random-secret
# Vercel Blob — token from Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
# Public URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Resend — API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Contact form — recipient email address
CONTACT_EMAIL=antoine@example.com
