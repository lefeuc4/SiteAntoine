{
  "name": "siteantoine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "payload migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed": "node --env-file=.env.local --import tsx/esm src/scripts/seed.ts",
    "seed:mentions": "node --env-file=.env.local --import tsx/esm src/scripts/seed-mentions-legales.ts",
    "seed:accueil": "node --env-file=.env.local --import tsx/esm src/scripts/seed-accueil.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/storage-vercel-blob": "^3.81.0",
    "@payloadcms/translations": "^3.81.0",
    "@payloadcms/ui": "^3.81.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.9.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "payload": "^3.81.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "resend": "^6.10.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
